# App
APP_NAME=EdenAI Teacher API
ENV=production
LOG_LEVEL=INFO
ENABLE_DOCS=false

# Security
JWT_SECRET_KEY=replace-with-a-strong-random-secret-32chars-min
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALLOW_PLAINTEXT_PASSWORD_COMPAT=false

# CORS / Host allow list (comma-separated)
CORS_ORIGINS=https://your-domain.example
TRUSTED_HOSTS=your-domain.example

# Database
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/eden_teacher

# Knowledge source
KNOWLEDGE_ENABLE_DB=true
KNOWLEDGE_ENABLE_STATIC=false
#KNOWLEDGE_STATIC_DIR=/opt/edenai-teacher/backend/app/data/company_docs

# LLM
GROQ_API_KEY=replace-with-your-groq-api-key
GROQ_BASE_URL=https://api.groq.com/openai
GROQ_MODEL=llama-3.1-8b-instant
